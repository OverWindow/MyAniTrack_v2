{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "server.ts",
    "config/**/*.ts",
    "routes/**/*.ts",
    "src/**/*.ts",
    "sync/**/*.ts",
    "translations/**/*.ts"
  ]
}
